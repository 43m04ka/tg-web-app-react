.container {
    width: 100%;
    min-height: 100vh;
    padding: 20px;
    background: linear-gradient(135deg, #f5e6d3 0%, #e8d4c0 50%, #dcc4af 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    overflow-y: auto;
}
