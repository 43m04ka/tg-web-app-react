// Цветовая палитра
$beige-light: #f5e6d3;
$beige-warm: #ede0cc;
$brown-light: #d4a574;
$brown-medium: #a67c52;
$brown-dark: #8b6f47;
$cream: #faf7f2;
$accent-warm: #c9945f;

.quizCard {
    max-width: 500px;
    width: 100%;
    padding: 32px;
    background: linear-gradient(135deg, $cream 0%, $beige-warm 100%);
    border-radius: 20px;
    box-shadow: 0 15px 50px rgba(139, 111, 71, 0.15),
                0 8px 25px rgba(212, 165, 116, 0.1);
    border: 2px solid $brown-light;
    position: relative;
    overflow: hidden;

    &::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, $brown-dark 0%, $accent-warm 50%, $brown-dark 100%);
    }
}

.questionCounter {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: $brown-medium;
    margin-bottom: 24px;
    opacity: 0.8;
}

.questionTitle {
    font-size: 20px;
    font-weight: 600;
    color: $brown-dark;
    margin-bottom: 20px;
    line-height: 1.4;
}

.imageContainer {
    width: 100%;
    margin-bottom: 24px;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(212, 165, 116, 0.15);
    background-color: #f8f4ed;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 10;
}

.image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: fadeIn 0.4s ease-out;
}

.optionsContainer {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
}

.option {
    width: 100%;
    padding: 16px;
    text-align: left;
    border: 2px solid #e0d1bd;
    border-radius: 12px;
    background-color: #ffffff;
    color: $brown-dark;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(212, 165, 116, 0.08);

    &:hover:not(:disabled) {
        border-color: $brown-light;
        background-color: $beige-light;
        box-shadow: 0 4px 12px rgba(212, 165, 116, 0.15);
        transform: translateY(-2px);
    }

    &:disabled {
        cursor: not-allowed;
    }

    &.selected {
        border-color: $brown-medium;
        background-color: #e8d7c3;
        color: $brown-dark;
        box-shadow: 0 4px 15px rgba(166, 124, 82, 0.2);
    }

    &.correct {
        border-color: #8fb5a8;
        background-color: #d9e8e2;
        color: #6b8f7f;
        box-shadow: 0 4px 15px rgba(143, 181, 168, 0.25);
    }

    &.incorrect {
        border-color: #b8a299;
        background-color: #e8d1c9;
        color: #8b6b5f;
        box-shadow: 0 4px 15px rgba(184, 162, 153, 0.25);
    }
}

.memoryNote {
    padding: 16px;
    background: linear-gradient(135deg, #f0e2d0 0%, #e8d9c4 100%);
    border-left: 4px solid $accent-warm;
    border-radius: 8px;
    font-size: 14px;
    color: $brown-dark;
    font-style: italic;
    line-height: 1.5;
    margin-bottom: 24px;
    animation: slideIn 0.3s ease-out;
}

.buttonContainer {
    display: flex;
    justify-content: flex-end;
}

.confirmBtn,
.nextBtn {
    padding: 12px 28px;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.3s ease;
}

.confirmBtn {
    background: linear-gradient(135deg, $brown-medium 0%, $brown-dark 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(139, 111, 71, 0.3);

    &:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(139, 111, 71, 0.4);
    }

    &:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
}

.nextBtn {
    background: linear-gradient(135deg, $accent-warm 0%, $brown-medium 100%);
    color: white;
    box-shadow: 0 4px 15px rgba(201, 148, 95, 0.3);

    &:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(201, 148, 95, 0.4);
    }
}

// Результаты
.resultCard {
    max-width: 500px;
    width: 100%;
    padding: 40px;
    background: linear-gradient(135deg, $cream 0%, $beige-warm 100%);
    border-radius: 20px;
    box-shadow: 0 15px 50px rgba(139, 111, 71, 0.15),
                0 8px 25px rgba(212, 165, 116, 0.1);
    border: 2px solid $brown-light;
    text-align: center;
    animation: scaleIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.resultTitle {
    font-size: 28px;
    font-weight: 700;
    color: $brown-dark;
    margin-bottom: 20px;
}

.resultScore {
    font-size: 22px;
    font-weight: 600;
    color: $brown-medium;
    margin-bottom: 16px;
}

.resultMessage {
    font-size: 16px;
    color: $brown-dark;
    margin-bottom: 32px;
    line-height: 1.6;
    font-style: italic;
}

.resultBtn {
    padding: 14px 32px;
    background: linear-gradient(135deg, $accent-warm 0%, $brown-medium 100%);
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 16px;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(201, 148, 95, 0.3);
    transition: all 0.3s ease;

    &:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(201, 148, 95, 0.4);
    }
}

// Анимации
@keyframes slideIn {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes scaleIn {
    from {
        opacity: 0;
        transform: scale(0.95);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}
