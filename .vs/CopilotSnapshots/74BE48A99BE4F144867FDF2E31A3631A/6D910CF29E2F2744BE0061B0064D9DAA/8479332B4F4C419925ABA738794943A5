@import "src/pages/AdminPanel/AdminPanel.module";

.main {
  z-index: 200;
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  margin: auto;
  background: rgba(0, 0, 0, 0.18);
  pointer-events: none;
}

.container {
  z-index: 200;
  position: absolute;
  top: 50%;
  left: 50%;
  height: max-content;
  width: min(860px, calc(100vw - 24px));
  max-height: calc(100vh - 48px);
  overflow-y: auto;
  background: linear-gradient(180deg, #081126 0%, #070d1b 100%);
  border: 1px solid #4f5f82;
  box-shadow: 0 26px 58px rgba(0, 0, 0, 0.55), inset 0 0 0 1px rgba(126, 146, 189, 0.12);
  border-radius: 18px;
  display: flex;
  flex-direction: column;
  padding: 12px;
  gap: 10px;
  pointer-events: auto;
}

.titleBar {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 2px 4px 0 4px;
  user-select: none;
  cursor: move;
}

.dragHandle {
  flex: 1;
  height: 4px;
  border-radius: 99px;
  background: linear-gradient(90deg, rgba(87, 101, 133, 0.8) 0%, rgba(122, 145, 194, 0.95) 50%, rgba(87, 101, 133, 0.8) 100%);
  box-shadow: inset 0 0 0 1px rgba(116, 132, 168, 0.35);
}

.title{
  @extend %text;
  margin-left: 8px;
  font-size: clamp(32px, 2.5vw, 42px) !important;
  line-height: 1;
  letter-spacing: -0.02em;
}

.closeButton {
  width: 28px;
  height: 28px;
  border: 1px solid #4e5a75;
  border-radius: 999px;
  background: #121a2d;
  color: #e4e8f2;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.closeButton:hover {
  background: #1b2742;
  border-color: #64779e;
}

