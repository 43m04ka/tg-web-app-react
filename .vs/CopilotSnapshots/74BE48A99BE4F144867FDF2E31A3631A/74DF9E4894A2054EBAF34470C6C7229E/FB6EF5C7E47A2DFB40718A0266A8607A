@import "src/pages/AdminPanel/AdminPanel.module";

.main {
  z-index: 200;
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  margin: auto;
  background: rgba(0, 0, 0, 0.4);
  pointer-events: none;
  backdrop-filter: blur(4px);
}

.container {
  z-index: 200;
  position: absolute;
  top: 50%;
  left: 50%;
  height: max-content;
  width: min(750px, calc(100vw - 32px));
  max-height: calc(100vh - 48px);
  overflow-y: auto;
  background: linear-gradient(135deg, #0f1419 0%, #161d2a 100%);
  border: 1px solid rgba(79, 95, 130, 0.4);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6), inset 0 1px 1px rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  display: flex;
  flex-direction: column;
  padding: 24px;
  gap: 16px;
  pointer-events: auto;
}

.titleBar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0;
  user-select: none;
  cursor: move;
  margin-bottom: 8px;
}

.dragHandle {
  flex: 1;
  height: 0;
  border-radius: 99px;
  background: transparent;
  box-shadow: none;
  display: none;
}

.title{
  @extend %text;
  margin-left: 0;
  font-size: 24px !important;
  line-height: 1.2;
  letter-spacing: -0.02em;
  color: #e4e8f2;
  font-weight: 600;
}

.closeButton {
  width: 32px;
  height: 32px;
  border: 1px solid rgba(79, 95, 130, 0.5);
  border-radius: 8px;
  background: rgba(18, 26, 45, 0.6);
  color: #e4e8f2;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  flex-shrink: 0;
  margin-left: auto;
}

.closeButton:hover {
  background: rgba(27, 39, 66, 0.8);
  border-color: rgba(100, 119, 158, 0.7);
}

