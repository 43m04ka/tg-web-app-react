import React, {useState} from 'react';
import style from './EditPageData.module.scss'
import useData from "../../../useData";
import {useServer} from "../useServer";
import PopUpWindow from "../../../Elements/PopUpWindow/PopUpWindow";
import useGlobalData from "../../../../../hooks/useGlobalData";

const EditPageData = ({onClose, updatePageList, id}) => {

    const platformOptions = [
        {name: 'vk-xbox'},
        {name: 'vk-ps'},
        {name: 'tg'},
        {name: 'web'}
    ];

    const {pageList} = useGlobalData();
    let pageData = {platform: 'tg', isHide: 1}
    pageList.map((item) => {
        if(item.id === id){
            pageData = item;
        }
    })
    const [infoLabel, setInfoLabel] = useState('*Поля обязательные для заполнения')
    const [updatePageJson, setUpdatePageJson] = useState({})

    const {authenticationData} = useData();
    const {updatePageData, createPage} = useServer()
    const selectedPlatform = updatePageJson.platform || pageData.platform || 'tg'

    const handleInputChange = (field, value) => {
        setUpdatePageJson(prev => ({
            ...prev,
            [field]: value
        }));
    }

    return (
        <PopUpWindow title={id === -1 ? 'Создать страницу' : 'Редактировать страницу'} onClose={onClose}>
            <div className={style['container']}>
                <div className={style['formSection']}>
                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Имя *</label>
                        <input 
                            className={style['inputField']}
                            type="text"
                            placeholder="Название страницы"
                            defaultValue={pageData.name}
                            onChange={(e) => handleInputChange('name', e.target.value)}
                        />
                    </div>

                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Ссылка *</label>
                        <input 
                            className={style['inputField']}
                            type="text"
                            placeholder="Путь страницы"
                            defaultValue={pageData.link}
                            onChange={(e) => handleInputChange('link', e.target.value)}
                        />
                    </div>

                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Изображение в переключателе</label>
                        <input 
                            className={style['inputField']}
                            type="text"
                            placeholder="URL изображения"
                            defaultValue={pageData.url}
                            onChange={(e) => handleInputChange('url', e.target.value)}
                        />
                    </div>

                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Изображение в баре</label>
                        <input 
                            className={style['inputField']}
                            type="text"
                            placeholder="URL изображения"
                            defaultValue={pageData.urlBar}
                            onChange={(e) => handleInputChange('urlBar', e.target.value)}
                        />
                    </div>

                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Порядковый номер</label>
                        <input 
                            className={style['inputField']}
                            type="number"
                            placeholder="0"
                            defaultValue={pageData.serialNumber}
                            onChange={(e) => handleInputChange('serialNumber', e.target.value)}
                        />
                    </div>

                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Цвет</label>
                        <input 
                            className={style['colorInput']}
                            type="color"
                            defaultValue={pageData.color || '#5B78E3'}
                            onChange={(e) => handleInputChange('color', e.target.value)}
                        />
                    </div>

                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Заголовок в сообщении</label>
                        <input 
                            className={style['inputField']}
                            type="text"
                            placeholder="Заголовок"
                            defaultValue={pageData.titleForMessage}
                            onChange={(e) => handleInputChange('titleForMessage', e.target.value)}
                        />
                    </div>

                    <div className={style['inputGroup']}>
                        <label className={style['label']}>Платформа</label>
                        <select 
                            className={style['selectField']}
                            defaultValue={selectedPlatform}
                            onChange={(e) => handleInputChange('platform', e.target.value)}
                        >
                            {platformOptions.map((option) => (
                                <option key={option.name} value={option.name}>
                                    {option.name}
                                </option>
                            ))}
                        </select>
                    </div>

                    <div className={style['switchField']}>
                        <input 
                            type="checkbox" 
                            id="displaySwitch"
                            defaultChecked={pageData.isHide === 0}
                            onChange={(e) => handleInputChange('isHide', e.target.checked ? 0 : 1)}
                        />
                        <label htmlFor="displaySwitch" className={style['switchLabel']}>
                            Отображение страницы в боте
                        </label>
                    </div>
                </div>

                <div className={style['infoLabel']}>
                    {infoLabel}
                </div>

                <div className={style['buttonPlace']}>
                    <div className={style['buttonCancel']} onClick={() => {
                        onClose();
                    }}>
                        <div/>
                        <p>Отмена</p>
                    </div>

                    <div className={style['buttonAccept']} onClick={async () => {
                        if (id === -1) {
                            const createPageJson = {
                                ...updatePageJson,
                                platform: updatePageJson.platform || pageData.platform || 'tg'
                            }
                            await createPage(() => {}, authenticationData, createPageJson)
                        } else {
                            await updatePageData(authenticationData, id, updatePageJson)
                        }
                        await updatePageList()
                        onClose();
                    }}>
                        <div/>
                        <p>Сохранить</p>
                    </div>
                </div>
            </div>
        </PopUpWindow>
    );
};

export default EditPageData;
