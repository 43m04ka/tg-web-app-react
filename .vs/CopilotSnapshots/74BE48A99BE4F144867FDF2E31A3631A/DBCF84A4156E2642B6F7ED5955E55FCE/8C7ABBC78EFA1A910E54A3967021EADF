@import "src/pages/AdminPanel/AdminPanel.module";

.container {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.formSection {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.inputGroup {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.label {
  @extend %text;
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #8e95a3;
}

.inputField {
  @extend %text;
  width: 100%;
  height: 36px;
  padding: 8px 12px;
  background-color: rgba(19, 21, 29, 0.6);
  border: 1px solid rgba(79, 95, 130, 0.4);
  border-radius: 8px;
  color: #e4e8f2;
  font-size: 14px;
  transition: all 0.2s ease;
  box-sizing: border-box;

  &:focus {
    outline: none;
    border-color: $theme-color;
    background-color: rgba(19, 21, 29, 0.8);
    box-shadow: 0 0 0 3px rgba($theme-color, 0.1);
  }

  &::placeholder {
    color: #5d6577;
  }
}

.colorInput {
  width: 100%;
  height: 44px;
  padding: 2px;
  background-color: rgba(19, 21, 29, 0.6);
  border: 1px solid rgba(79, 95, 130, 0.4);
  border-radius: 8px;
  cursor: pointer;
  box-sizing: border-box;

  &:focus {
    outline: none;
    border-color: $theme-color;
  }
}

.selectField {
  @extend %text;
  width: 100%;
  height: 36px;
  padding: 8px 12px;
  background-color: rgba(19, 21, 29, 0.6);
  border: 1px solid rgba(79, 95, 130, 0.4);
  border-radius: 8px;
  color: #e4e8f2;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.2s ease;

  &:focus {
    outline: none;
    border-color: $theme-color;
  }

  &:hover {
    border-color: rgba(79, 95, 130, 0.6);
  }
}

.switchField {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background: rgba(79, 95, 130, 0.1);
  border: 1px solid rgba(79, 95, 130, 0.2);
  border-radius: 8px;
}

.switchLabel {
  @extend %text;
  font-size: 14px;
  color: #e4e8f2;
  margin: 0;
}

.infoLabel {
  @extend %text;
  margin: 12px 0 0 0;
  font-size: 12px;
  color: #8e95a3;
  font-style: italic;
}

.buttonPlace {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid rgba(79, 95, 130, 0.2);
}

.buttonAccept {
  @extend %button;
  background: $theme-color;
  padding: 8px 16px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
  font-weight: 600;

  > div {
    width: 16px;
    height: 16px;
    background-size: cover;
    background-image: url('data:image/png;base64,');
  }

  > p {
    margin: 0;
    font-size: 14px;
  }
}

.buttonCancel {
  @extend %button;
  background: rgba(79, 95, 130, 0.2);
  border-color: rgba(79, 95, 130, 0.4);
  padding: 8px 16px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
  font-weight: 600;
  color: #e4e8f2;

  > div {
    width: 16px;
    height: 16px;
    background-size: cover;
    background-image: url('data:image/png;base64,');
  }

  > p {
    margin: 0;
    font-size: 14px;
  }
}

.buttonAccept:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.buttonCancel:hover {
  background: rgba(79, 95, 130, 0.3);
}
