@import "src/pages/AdminPanel/AdminPanel.module";

.mainContainer {
  width: 100%;
  height: 100%;
  min-height: 100vh;
  padding: 40px;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 0 0 24px 0;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.headerTitle {
  @extend %text;
  font-size: 28px;
  font-weight: 700;
  color: $text-color;
}

.headerControls {
  display: flex;
  flex-direction: row;
  gap: 12px;
  align-items: center;
}

.inputFind {
  @extend %text;
  display: block;
  width: 320px;
  height: 33px;
  padding: 0.375rem 0.75rem;
  font-weight: 400;
  line-height: 1.5;
  color: $text-color;
  background-color: $bg-color;
  background-clip: padding-box;
  border: 1px solid $theme-color;
  border-radius: 7px;
  transition: border-color 0.5s ease-in-out, box-shadow 0.15s ease-in-out;

  &:focus {
    outline: none;
    border-color: $theme-color;
    box-shadow: 0 0 0 0.2rem rgba($theme-color, 0.25);
  }
}

.buttonGroup {
  display: flex;
  gap: 8px;
}

.button {
  @extend %button;
  background: $theme-color;
  padding: 6px 12px;
  border-radius: 7px;
  display: flex;
  align-items: center;
  gap: 6px;

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  > p {
    margin: 0;
    font-size: 12px;
  }
}

.tableWrapMain {
  width: 100%;
  overflow: auto;
  max-height: calc(100vh - 230px);
  min-height: 320px;
  flex: 1 1 auto;
  min-width: 0;
  border: 1px solid #2c2c2e;
  border-radius: 14px;
  background: #13151d;
}

.table {
  width: 100%;
  border-collapse: collapse;
  min-width: 900px;
  table-layout: fixed;

  th,
  td {
    @extend %text;
    padding: 12px 14px;
    border-bottom: 1px solid #242730;
    text-align: left;
    white-space: normal;
    word-break: break-word;
  }

  thead th {
    color: #8e95a3;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: #11131a;
    position: sticky;
    top: 0;
    z-index: 1;
  }

  tbody tr {
    cursor: pointer;
    transition: background-color 0.2s ease;

    &:hover {
      background: rgba(91, 120, 227, 0.08);
    }

    &:last-child td {
      border-bottom: none;
    }
  }
}

.actionButton {
  @extend %button;
  padding: 4px 10px;
  border-color: #2f3850;
  background: #1a2234;
  white-space: nowrap;
  font-size: 12px;

  > p {
    margin: 0;
  }
}

.emptyCell {
  color: #8e95a3 !important;
  text-align: center !important;
  padding: 20px !important;
}

.infoLabel {
  @extend %text;
  margin: 12px 0 0 0;
  font-size: 14px;
  color: #a0a8b8;
}
