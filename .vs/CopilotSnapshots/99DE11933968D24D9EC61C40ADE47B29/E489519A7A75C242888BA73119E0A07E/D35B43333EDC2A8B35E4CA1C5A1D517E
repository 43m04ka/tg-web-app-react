import React from 'react';
import {Link, useNavigate} from "react-router-dom";
import CatalogItem from "../Catalog/CatalogItem";
import style from './HomeBlock.module.scss';

const HomeBlock = ({data}) => {

    const navigate = useNavigate();

    let styleBlock = {}
    let borderClasses = ''
    if (data.isRoundedBorderTop) borderClasses += ` ${style['roundedTop']}`;
    if (data.isRoundedBorderBottom) borderClasses += ` ${style['roundedBottom']}`;

    if (data.type.includes('banner')) {
        if (data.backgroundColor !== 'none' && typeof data.backgroundColor !== 'undefined') {
            styleBlock = {
                background: data.backgroundColor,
                paddingBottom: '15px',
                overflow: 'hidden',
            }
        } else {
            styleBlock = {
                paddingTop: '5px',
                paddingBottom: '15px',
                marginTop: '10px',
            }
        }
    } else {
        if (data.backgroundColor !== 'none') {
            if (data.name !== '') {
                styleBlock = {
                    background: data.backgroundColor,
                    paddingBottom: '10px',
                    paddingTop: '10px',
                    marginTop: '0px',
                    paddingLeft: '7px',
                    marginBottom: '10px',
                }
            } else {
                styleBlock = {
                    background: data.backgroundColor,
                    paddingBottom: '10px',
                    paddingTop: '0',
                    marginTop: '-15px',
                    paddingLeft: '7px',
                    marginBottom: '10px',
                }
            }
        } else {
            styleBlock = {
                paddingBottom: '0px', paddingTop: '3px', paddingLeft: '7px', marginTop: '0px', marginBottom: '10px'
            };
        }
    }

    let link = '/catalog/'
    if (data.type === 'ordinary-choice') {
        link = '/choice-catalog/'
    }

    if (!data.type.includes('banner')) {
        return (<div style={styleBlock} className={borderClasses.trim()}>
            <div className={style['desktopContainer']}>
                <div style={{display: 'flex', flexDirection: 'row', marginTop: '15px'}}>
                    {typeof data.imageIcon !== 'undefined' && data.imageIcon !== null ? (<div className={style['iconImage']} style={{
                        backgroundImage: 'url(' + data.imageIcon + ')'
                    }}/>) : ''}
                    <div className={style['titleText']}>{data.name}</div>
                </div>
                <div className={"scroll-container"} style={{alignItems: 'center'}}>
                    {data.body.slice(0, 6).map(item => (<div key={item.id} style={{marginRight: '15px', marginTop: '1vw'}}>
                        <CatalogItem key={item.id} product={item}/>
                    </div>))}
                </div>
                <div style={{width: '100%', display: 'flex'}}>
                    <button onClick={() => navigate(link + data.path)} className={style['openButton']}>
                        Открыть каталог
                    </button>
                </div>
            </div>
        </div>);
    } else if (data.type.includes('banner')) {
        return (<div className={`homeBlock ${style['bannerBlock']} ${borderClasses.trim()}`}
                     style={styleBlock}>
            <Link to={data.path} className={'link-element'}>
                <div className={style['bannerImg']} style={{
                    backgroundImage: "url('" + data.url + "')"
                }}></div>
            </Link>
        </div>)
    }


};

export default HomeBlock;
