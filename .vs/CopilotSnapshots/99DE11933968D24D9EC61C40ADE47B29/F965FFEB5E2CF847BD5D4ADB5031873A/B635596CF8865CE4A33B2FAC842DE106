.titleText {
  font-size: 6vw;
  line-height: 9vw;
  font-weight: normal;
  font-family: 'SF PRO Display', sans-serif;
  color: white;
  margin-left: 1vw;
  overflow: hidden;
  width: auto;
  letter-spacing: 0.1vw;
}

.iconImage {
  height: 9vw;
  width: 9vw;
  margin-left: 0.5vw;
  background-size: cover;
}

.openButton {
  font-weight: normal;
  font-family: 'SF PRO Display', sans-serif;
  color: white;
  border-radius: 1.5vw;
  background-color: #222222;
  padding: 10px 12px;
  width: max-content;
  font-size: 3.6vw;
  justify-items: center;
  margin: 10px auto 0 auto;
  border: none;
  cursor: pointer;
}

.bannerImg {
  height: 40vw;
  background-size: cover;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
}

.roundedTop {
  border-top-left-radius: 6vw;
  border-top-right-radius: 6vw;
}

.roundedBottom {
  border-bottom-left-radius: 6vw;
  border-bottom-right-radius: 6vw;
}

@media (min-width: 768px) {
  .titleText {
    font-size: 32px;
    line-height: 40px;
    margin-left: 8px;
    letter-spacing: 1px;
    font-weight: bolder;
  }

  .iconImage {
    height: 40px;
    width: 40px;
    margin-left: 4px;
    margin-top: 4px;
  }

  .openButton {
    font-size: 16px;
    border-radius: 8px;
    padding: 12px 24px;
    margin-top: 25px;
    margin-bottom: 15px;
  }

  .bannerImg {
    height: 350px;
    margin: 0 auto;
    width: 100%;
    border-radius: 20px;
    background-position: center;
  }

  .roundedTop {
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
  }

  .roundedBottom {
    border-bottom-left-radius: 20px;
    border-bottom-right-radius: 20px;
  }

  .bannerBlock {
     margin: 0 auto;
     padding: 0;
     width: 1300px;
  }

  .homeBlock {
      width: 1300px;
      margin: 0 auto !important;
      padding-left: 45px !important;
      padding-right: 45px !important;
      box-sizing: border-box;
  }

  .desktopContainer {
      width: 100%;
      margin: 0 auto;    
  }
}
