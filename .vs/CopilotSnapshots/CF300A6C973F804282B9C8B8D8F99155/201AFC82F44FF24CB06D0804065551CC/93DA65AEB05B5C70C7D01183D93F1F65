@import "src/pages/AdminPanel/AdminPanel.module";

.main {
  z-index: 200;
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  margin: auto;
  background: rgba(0, 0, 0, 0.18);
}

.container {
  z-index: 200;
  position: absolute;
  top: 50%;
  left: 50%;
  height: max-content;
  width: min(860px, calc(100vw - 32px));
  max-height: calc(100vh - 48px);
  overflow-y: auto;
  background-color: $bg-color;
  border: 2px solid $secondary-color;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
  border-radius: 20px;
  display: grid;
  padding: 12px;
  grid-template-rows: 40px max-content;
}

.title{
  @extend %text;
  margin-top: 8px;
  margin-left: 15px;
  font-size: 20px !important;
  user-select: none;
  cursor: move;
}

