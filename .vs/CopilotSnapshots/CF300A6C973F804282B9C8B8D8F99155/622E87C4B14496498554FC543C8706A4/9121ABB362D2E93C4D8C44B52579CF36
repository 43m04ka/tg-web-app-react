import React from 'react';
import style from './PopUpWindow.module.scss';

const PopUpWindow = ({children, title, onClose}) => {
    const [position, setPosition] = React.useState({x: 0, y: 0});
    const dragStateRef = React.useRef({dragging: false, startX: 0, startY: 0, originX: 0, originY: 0});
    const containerRef = React.useRef(null);

    React.useEffect(() => {
        const onMouseMove = (event) => {
            if (!dragStateRef.current.dragging) return;

            const rawX = dragStateRef.current.originX + (event.clientX - dragStateRef.current.startX);
            const rawY = dragStateRef.current.originY + (event.clientY - dragStateRef.current.startY);

            const container = containerRef.current;
            if (!container) {
                setPosition({x: rawX, y: rawY});
                return;
            }

            const halfWidth = container.offsetWidth / 2;
            const halfHeight = container.offsetHeight / 2;

            const minX = -window.innerWidth / 2 + halfWidth + 8;
            const maxX = window.innerWidth / 2 - halfWidth - 8;
            const minY = -window.innerHeight / 2 + halfHeight + 8;
            const maxY = window.innerHeight / 2 - halfHeight - 8;

            const boundedX = minX <= maxX ? Math.min(Math.max(rawX, minX), maxX) : 0;
            const boundedY = minY <= maxY ? Math.min(Math.max(rawY, minY), maxY) : 0;

            const nextX = Number.isFinite(boundedX) ? boundedX : 0;
            const nextY = Number.isFinite(boundedY) ? boundedY : 0;
            setPosition({x: nextX, y: nextY});
        };

        const onMouseUp = () => {
            dragStateRef.current.dragging = false;
        };

        window.addEventListener('mousemove', onMouseMove);
        window.addEventListener('mouseup', onMouseUp);

        return () => {
            window.removeEventListener('mousemove', onMouseMove);
            window.removeEventListener('mouseup', onMouseUp);
        };
    }, []);

    const startDrag = (event) => {
        dragStateRef.current = {
            dragging: true,
            startX: event.clientX,
            startY: event.clientY,
            originX: position.x,
            originY: position.y
        };
    };

    return (
        <div className={style['main']}>
            <div ref={containerRef} className={style['container']} style={{
                transform: `translate(calc(-50% + ${position.x}px), calc(-50% + ${position.y}px))`
            }}>
                <div className={style['titleBar']} onMouseDown={startDrag}>
                    <div className={style['titleWrap']}>
                        <div className={style['dragHandle']}/>
                        <div className={style['title']}>{title}</div>
                    </div>
                    {onClose ? <button
                        className={style['closeButton']}
                        onMouseDown={(event) => event.stopPropagation()}
                        onClick={onClose}
                    >
                        ✕
                    </button> : ''}
                </div>
                <div>
                    {children}
                </div>
            </div>
        </div>
    );
};

export default PopUpWindow;
