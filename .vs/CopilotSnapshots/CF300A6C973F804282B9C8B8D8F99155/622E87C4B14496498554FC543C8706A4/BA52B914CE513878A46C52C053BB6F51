@import "src/pages/AdminPanel/AdminPanel.module";

.main {
  z-index: 200;
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  margin: auto;
  background: rgba(0, 0, 0, 0.18);
  pointer-events: none;
}

.container {
  z-index: 200;
  position: absolute;
  top: 50%;
  left: 50%;
  height: max-content;
  width: min(860px, calc(100vw - 32px));
  max-height: calc(100vh - 48px);
  overflow-y: auto;
  background-color: $bg-color;
  border: 2px solid $secondary-color;
  box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
  border-radius: 20px;
  display: grid;
  padding: 12px;
  grid-template-rows: 40px max-content;
  pointer-events: auto;
}

.titleBar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-right: 8px;
  user-select: none;
  cursor: move;
}

.titleWrap {
  display: flex;
  align-items: center;
  gap: 10px;
}

.dragHandle {
  width: 46px;
  height: 6px;
  border-radius: 99px;
  background: linear-gradient(90deg, #3a4254 0%, #5a6684 50%, #3a4254 100%);
  opacity: 0.9;
  box-shadow: 0 0 0 1px rgba(120, 136, 174, 0.2);
}

.title{
  @extend %text;
  margin-top: 8px;
  margin-left: 15px;
  font-size: 20px !important;
}

.closeButton {
  width: 30px;
  height: 30px;
  border: 1px solid #3d4556;
  border-radius: 8px;
  background: #1a2234;
  color: #d5d9e2;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.closeButton:hover {
  background: #242f49;
  border-color: #4f5d79;
}

