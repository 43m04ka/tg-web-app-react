const fs = require('fs');

const filePath = 'src/pages/MoreInfo/MoreInfo.jsx';
let content = fs.readFileSync(filePath, 'utf8');

const allBots = "['vk-xbox', 'vk-ps', 'tg', 'web']";

const map = {
  'Избранное': allBots,
  'История заказов': allBots,
  'Поддержка магазина': allBots,
  'Сообщество Геймворд | Xbox': "['tg', 'web']",
  'Сообщество Геймворд | PlayStation': "['tg', 'web']",
  'Канал Геймворд | Xbox': "['vk-xbox', 'web']",
  'Канал Геймворд | PlayStation': "['vk-ps', 'web']",
  'Пользовательское соглашение': allBots,
  'Политика конфиденциальности': allBots,
  'Инструкции для PlayStation': "['vk-ps', 'tg', 'web']",
  'Инструкции для Xbox': "['vk-xbox', 'tg', 'web']"
};

content = content.replace(/(name:\s*'([^']+)',\s*\n)(\s*)(?!bots:)/g, (m, p1, name, indent) => {
  const bots = map[name] || allBots;
  return `${p1}${indent}bots: ${bots},\n`;
});

fs.writeFileSync(filePath, content);
console.log('Updated bots in buttonList');
