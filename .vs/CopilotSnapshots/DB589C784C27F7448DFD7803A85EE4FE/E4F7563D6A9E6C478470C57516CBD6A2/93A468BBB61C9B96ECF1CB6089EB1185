@import "src/app/styles/mainStyle";

.catalogItem {
  display: flex;
  border-radius: $block-border-radius / 2;
  margin-top: 3vw;
  position: relative;
  width: 41vw;
  height: 57.5vw;
  min-height: 57.5vw;
  min-width: 41vw;
  box-sizing: border-box;

  > div:nth-child(1) {
    position: relative;
    width: 41vw;
    height: 57.5vw;
    min-height: 57.5vw;
    min-width: 41vw;
    box-sizing: border-box;
    overflow: hidden;
    border-radius: $block-border-radius / 2;

    > img {
      display: flex;
      width: 41vw;
      height: 41vw;
      border-radius: $block-border-radius / 2;
    }

    > div {
      display: flex;
      width: 41vw;
      height: 41vw;
      border-radius: $block-border-radius / 2;
    }
  }


  .gradient {
    position: absolute;
    width: 41.0vw;
    height: 56.5vw;
    padding: 0.5vw;
    background: linear-gradient(180deg, #00000000 55%, rgba(34, 34, 34, 0.93) 65%, $menu-color 80%);
    display: flex;
    flex-direction: column;
    border-radius: $block-border-radius / 2;

    .cardName {
      display: flex;
      margin: 2vw 1.55vw 0 1.55vw;
      height: 9.4vw;
      min-height: 9.4vw;
      max-height: 9.4vw;
      overflow: hidden;
      >p{
        display: flex;
        height: max-content;
        margin: auto 0;
        font-size: 3.5vw;
        line-height: 4.6vw;
        font-family: 'SF PRO Display', serif;
        font-weight: 500;
        color: white;
      }
    }

    .cardPrice {
      display: flex;
      margin: 0 1.55vw 0 1.55vw;
      font-size: 3.5vw;
      height: 6.3vw;
      min-height: 6.3vw;
      max-height: 6.3vw;
      overflow: hidden;
      line-height: 6.3vw;
      font-family: 'SF PRO Display', serif;
      font-variant: normal;
      font-weight: 900;
      color: white;
    }

    .parcent {
      background: #EFD101;
      margin: auto auto auto 1vw;
      padding: 0.63vw 1.26vw;
      font-family: 'SF PRO Display', serif;
      border-radius: $block-border-radius / 4;
      color: black;
      font-size: 2.2vw;
      line-height: 2.7vw;
      font-weight: 900;
      height: max-content;
    }

    .platform {
      margin: auto 1.55vw 0 1.55vw;
      display: flex;
      flex-direction: row;

      > div {
        background: white;
        padding: 0.63vw 1.26vw;
        font-family: 'SF PRO Display', serif;
        border-radius: $block-border-radius / 4;
        color: black;
        font-size: 2.2vw;
        line-height: 2.7vw;
        font-weight: 900;
        height: max-content;
      }
    }
  }

  @media (min-width: 768px) {
    width: 200px;
    height: 280px;
    min-height: 280px;
    min-width: 200px;
    border-radius: 12px;
    margin-top: 15px;

    > div:nth-child(1) {
      width: 200px;
      height: 280px;
      min-height: 280px;
      min-width: 200px;
      border-radius: 12px;

      > img {
        width: 200px;
        height: 200px;
        border-radius: 12px;
      }

      > div {
        width: 200px;
        height: 200px;
        border-radius: 12px;
      }
    }

    .gradient {
      width: 200px;
      height: 275px;
      padding: 3px;
      border-radius: 12px;

      .cardName {
        margin: 10px 8px 0 8px;
        height: 45px;
        min-height: 45px;
        max-height: 45px;
        > p {
          font-size: 16px;
          line-height: 20px;
        }
      }

      .cardPrice {
        margin: 0 8px;
        font-size: 16px;
        height: 30px;
        min-height: 30px;
        max-height: 30px;
        line-height: 30px;
      }

      .parcent {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        line-height: 13px;
      }

      .platform {
        margin: auto 8px 0 8px;
        > div {
          padding: 4px 8px;
          border-radius: 4px;
          font-size: 11px;
          line-height: 13px;
        }
      }
    }
  }
}